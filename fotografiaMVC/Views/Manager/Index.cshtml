            <div class="pagination">
                <span>‹</span>
                <div class="page-pill active">1</div>
                <div class="page-pill">2</div>
                <span>›</span>
            </div>
        </section>
        @using (Html.BeginForm("Update", "Manager", FormMethod.Post))
        {
            <aside class="panel">
                <h2 class="section-title">Contact Information</h2>
                <div class="field">
                    <label class="label"><span class="emoji">👤</span> Username</label>
                    <input id="inputUsername" type="text" placeholder="Enter new username" name="Username"/>
                </div>
                <div class="field">
                    <label class="label"><span class="emoji">✉</span> Email Address</label>
                    <input ID="inputEmail" type="email" placeholder="name.lastname@example.com" name="Email"/>
                </div>

                <div class="field">
                    <label class="label"><span class="emoji">☎</span> Phone Number</label>
                    <input ID="inputPhoneNumber" type="text" placeholder="(+55) 2228654931" name="Phone"/>
                </div>

                <div class="field">
                    <label class="label"><span class="emoji">📍</span> Location</label>
                    <input ID="inputLocation" type="text" placeholder="Puebla, Mexico" name="Location"/>
                </div>

                <div class="field">
                    <label class="label"><span class="emoji">◎</span> Instagram</label>
                    <input id="inputInstagram" type="text" placeholder="InstagramProfile" name="Instagram"/>
                </div>
                <div class="field">
                    <label class="label"><span class="emoji">📘</span> Facebook</label>
                    <input id="inputFacebook" type="text" placeholder="FacebookProfile" name="Facebook"/>
                </div>

                <div class="field">
                    <label class="label"><span class="emoji">✎</span> Bio</label>
                    <textarea id="inputBio" rows="5" placeholder="Landscape and cultural photographer based in Mexico." name="Description"></textarea>
                </div>

                <button type="submit" class="btn save-btn" Text="Update info" />
            </aside>
        }
        </main>
</div>

